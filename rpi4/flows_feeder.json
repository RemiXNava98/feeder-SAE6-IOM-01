        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "topic",
        "x": 620,
        "y": 300,
        "wires": []
    },
    {
        "id": "n_debug_errors",
        "type": "debug",
        "z": "feeder_tab",
        "name": "debug errors",
        "active": true,
        "tosidebar": true,
        "console": false,
